@startuml Gymanice_Login_Activity

title Gymanice — Login & Reset Password

skinparam Activity {
  BackgroundColor #AEC6EB
  BorderColor #5D6D7E
  DiamondBackgroundColor #AEC6EB
  DiamondBorderColor #5D6D7E
  ArrowColor #1A5276
  FontName Arial
}
skinparam shadowing false

start

repeat
  :Enter Username\n/ Email;
  :Enter Password;
  :Validate\nCredentials;
  
  if (Credentials\nvalid?) then (Yes)
    :login\nsuccessful;
    :Go to home\nbage;
    end
  else (No)
    if (Forget\npassword) then (Yes)
      :Reset\npassword;
      :Send\nReset Link;
      :Set New\nPassword;
    else (No)
      :Show Error\nMessage;
    endif
  endif
repeat while ()

@enduml
